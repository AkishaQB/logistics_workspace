// For customization, see https://containers.dev/implementors/json_reference/
{
  "name": "AK Logistics - Full Stack",
  "workspaceFolder": "/workspace",

  // Point to the root-level docker-compose
  "dockerComposeFile": "../docker-compose.yml",

  // Use the workspace container as the VS Code workspace.
  "service": "workspace",
  "runServices": ["courier-track-db", "courier-logistics-db"],
  "shutdownAction": "stopCompose",
  // Forward both Postgres ports to your host
  "forwardPorts": [5433, 5435],
  // Labels for the VS Code Ports panel
  "portsAttributes": {
    "5433": {
      "label": "PostgreSQL – courier-track-be",
      "onAutoForward": "silent"
    },
    "5435": {
      "label": "PostgreSQL – courier-logistics-be",
      "onAutoForward": "silent"
    }
  },

  // Run after container is created
  "postCreateCommand": "echo '✅ courier-track-db on localhost:5433 | courier-logistics-db on localhost:5435'",

  // VS Code extensions installed in every workspace opened with this devcontainer
  "customizations": {
    "vscode": {
      "extensions": [
        "Prisma.prisma",
        "ms-azuretools.vscode-docker",
        "ckolkman.vscode-postgres"
      ]
    }
  }
}
